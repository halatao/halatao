{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "halatao",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-07-12",
  "workers_dev": true,
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash",
    "run_worker_first": true
  }
}

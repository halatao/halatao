{
  "name": "halatao",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate:worker-redirects && next build",
    "start": "next start",
    "lint": "eslint .",
    "generate:worker-redirects": "tsx scripts/generate-worker-redirects.ts",
    "test:edge-redirects": "tsx scripts/test-edge-redirects.ts",
    "test:worker": "tsx --test worker/test/redirect-worker.test.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "validate:redirects": "tsx scripts/validate-redirects.ts",
    "validate:seo": "tsx scripts/validate-seo.ts",
    "validate:worker-assets": "tsx scripts/validate-worker-assets.ts",
    "validate:worker-redirects": "tsx scripts/validate-worker-redirects.ts",
    "build:worker": "wrangler deploy --dry-run --config wrangler.jsonc --outdir dist/worker"
  },
  "keywords": [
    "nextjs",
    "static-site",
    "bilingual"
  ],
  "author": "Ondrej Halata",
  "license": "UNLICENSED",
  "description": "Commercial bilingual Next.js website for Halatao.cz",
  "dependencies": {
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.7",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "wrangler": "^4.102.0"
  }
}
